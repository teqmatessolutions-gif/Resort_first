# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/resort_db

# JWT Configuration
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "https://teqmates.com", "https://www.teqmates.com"]

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=["jpg", "jpeg", "png", "gif", "pdf"]

# Email Configuration (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@teqmates.com

# Payment Gateway Configuration (if needed)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# External API Configuration
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GEMINI_API_KEY=your_gemini_api_key_for_chatbot

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False
ENVIRONMENT=production

# Redis Configuration (for caching, if needed)
REDIS_URL=redis://localhost:6379

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/resort_app.log

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=3600

# Resort Information
RESORT_NAME=Elysian Retreat
RESORT_EMAIL=info@teqmates.com
RESORT_PHONE=+1234567890
RESORT_ADDRESS=Your Resort Address
